{
  "name": "@discourse/lint-configs",
  "version": "3.1.1",
  "description": "Shareable lint configs for Discourse core, plugins, and themes",
  "author": "Discourse",
  "license": "MIT",
  "keywords": [
    "discourse"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/discourse/lint-configs.git"
  },
  "homepage": "https://github.com/discourse/lint-configs#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    "./eslint": "./eslint.mjs",
    "./eslint-theme": "./eslint-theme.mjs",
    "./prettier": {
      "require": "./.prettierrc.cjs"
    },
    "./stylelint": "./stylelint.mjs"
  },
  "scripts": {
    "lint": "eslint --no-error-on-unmatched-pattern \"**/*.{cjs,mjs,js}\" && pnpm prettier --check \"**/*.{cjs,mjs,js}\"",
    "test": "cd ../test && node test.js"
  },
  "dependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/plugin-proposal-decorators": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-decorator-position": "^6.1.0",
    "eslint-plugin-ember": "^13.4.0",
    "eslint-plugin-qunit": "^8.2.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-class-members": "^1.22.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "eslint": "10.5.0",
    "prettier": "3.8.1",
    "stylelint": "17.5.0"
  }
}
